# ============================================================================
# YUJIN AI TRADER · 环境变量模板 (脱敏 · 悟空填)
# ============================================================================
# ⚠️  此文件不入 git (已配 .gitignore) | .env.example 入 git 供参照
# ⚠️  凭据不入对话 · 不入代码 · 不入 git · 不入日志 (风险登记 ROADMAP.md #5)
# ⚠️  使用口: cp .env.example .env  后填真实参,启动前 chmod 600 .env
# ============================================================================


# ----- MT5 券商凭据 ·  悟空填  FTMO 模拟账号 + 	path   -----
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_LOGIN=12345678
MT5_PASSWORD=********
MT5_SERVER=FTMO-Demo


# ----- 数据源模式 (Phase 8 switch)  -----
# SHADOW         - 仅走 SEED_SYMBOLS 摸拟数据(未设置 默认)
# LIVE_DRY_RUN   - 走 MT5 真行情但禁下单(灰度上线验证)
# LIVE           - MT5 真行情 + 真下单(需悟空明示授权)
MT5_DATA_MODE=SHADOW


# ----- MT5 重连策略 (指数退避)  -----
# 起始退避 5s · 上限 60s · 心跳探测间隔 30s
MT5_RECONNECT_BASE_S=5
MT5_RECONNECT_MAX_S=60
MT5_HEARTBEAT_S=30


# ----- 应用服务 -----
APP_HOST=0.0.0.0
APP_PORT=8000


# ----- 交易权限闸门 ·  悟空受控 live 后才改 false   -----
LIVE_TRADING_DISABLED=true


# ----- 风控限额 -----
RISK_AMOUNT_USD=300
MAX_CONCURRENT_POSITIONS=3
DAILY_LOSS_CAP_USD=300

# ========================================================
# 上线顺序(参考 ROADMAP.md) :
#   1. .env 填 MT5 凭据 (로그凭证在   .gitignore)
#   2. MT5_DATA_MODE = LIVE_DRY_RUN · curl /api/health/mt5 检查
#   3. 灰度跑 24h 后 MT5_DATA_MODE = LIVE · 悟空明示授权
# ========================================================
