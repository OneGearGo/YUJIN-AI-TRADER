# MT5 凭据(运行时填,不进仓库)
MT5_LOGIN=YOUR_LOGIN
MT5_PASSWORD=YOUR_PASSWORD
MT5_SERVER=YOUR_SERVER
MT5_PATH=YOUR_MT5_PATH

# 应用
APP_HOST=127.0.0.1
APP_PORT=8000
LIVE_TRADING_DISABLED=false

# 风控(FTMO 10K 一阶段默认)
RISK_AMOUNT_USD=50
MAX_CONCURRENT_POSITIONS=3
DAILY_LOSS_CAP_USD=300
MAX_TOTAL_EXPOSURE_PCT=30
KILL_SWITCH_CONSEC_LOSSES=3

# 扫描
SCAN_INTERVAL_SEC=5
SYMBOLS=XAUUSD

# LLM(可选,阶段 8 启用)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
