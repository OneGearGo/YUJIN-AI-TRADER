# 凭据
.env
*.env.local

# 运行时数据
outputs/*.json
outputs/*.jsonl

# MT5 文件
*.set
*.ex5

# 系统
__pycache__/
*.pyc
.venv/
venv/
nul

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# 测试临时
test_outputs/
*.log
# .github/workflows was directory-level blacklist -> needed git add -f for every
# new workflow file. Switched to explicit .yml allowlist; transient artifacts
# (.lock, cache, etc.) remain ignored.
.github/workflows/*
!.github/workflows/*.yml
# local-only test artifacts (baseline PNGs, .pre-refresh.bak/); prevent accidental
# git add . from polluting the source-of-truth with binary diffs.
tests/artifacts/
docs/reference/

# GitHub Actions(workflow files 需 token workflow scope 才能 push)
KEY.txt
# 推断型凭据文件兜底
*.key
*.secret
*.pem
credentials.txt
*_creds.*
secrets/

# virtual env
.venv311/
.env.bak*
*/.env.bak*

# Broker profile local overrides (per-account machine-only)
# Tracked template lives at config/profiles/moneta.yaml;
# per-account credentials/paths MUST NOT be committed. Three explicit
# covers the standard override naming shapes; broad `*.local*` patterns
# are intentionally avoided because they would also catch unrelated names
# like `.localhost`, `.localize`, `.local-debug.yaml`.
config/profiles/*.local
config/profiles/*.local.yaml
config/profiles/*.local.yml
# ============================================================
# Polish-script crash-leftover suppression (Polish #6.3)
# ============================================================
# Auto-suppresses stale snapshot directories and files that may
# accumulate in the working tree when a polish-script applier
# (_apply_*.py living at /Desktop during Polish #5.x deploys) crashes
# mid-write before the cp-back step. Without these patterns:
#   - git status shows the snapshot as untracked junk
#   - reviewers cannot easily distinguish from a real on-disk delta
#   - working tree hygiene degrades faster than operational cleanup
#
# Patterns below are exhaustive for the Polish #5.x crash pattern;
# extend if future polish-scripts emit different backup conventions.
# Verified with `git check-ignore -v <synthetic-path>` after each commit.
# ============================================================
*.bak
.bak*/
.tmp_patch_backup/
.tmp_patch_*/
